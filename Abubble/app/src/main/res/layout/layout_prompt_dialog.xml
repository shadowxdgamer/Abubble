<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/prompt_root"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_prompt_card_v2"
    android:clipChildren="true"
    android:clipToPadding="true"
    android:elevation="24dp"
    android:orientation="vertical">

    <!-- ── Header Bar ── -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#673AB7"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <ImageView
            android:id="@+id/header_logo"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_abubble_logo" />

        <TextView
            android:id="@+id/prompt_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:layout_toEndOf="@id/header_logo"
            android:text="@string/prompt_title"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/close"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#B39DDB" />
    </RelativeLayout>

    <!-- ── Body ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Context Preview -->
        <TextView
            android:id="@+id/tv_context_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/context_label"
            android:textColor="#7E57C2"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_context_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_context_box"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:maxLines="3"
            android:padding="12dp"
            android:text="@string/no_context"
            android:textColor="#424242"
            android:textSize="13sp" />

        <!-- Model Selector -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/model_label"
            android:textColor="#7E57C2"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinner_model"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_spinner"
            android:paddingHorizontal="12dp" />

        <!-- Reasoning Toggle -->
        <LinearLayout
            android:id="@+id/reasoning_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_context_box"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@drawable/ic_brain"
                android:drawablePadding="8dp"
                android:drawableTint="#673AB7"
                android:text="@string/reasoning_label"
                android:textColor="#424242"
                android:textSize="13sp" />

            <Switch
                android:id="@+id/switch_reasoning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#673AB7"
                android:trackTint="#D1C4E9" />
        </LinearLayout>

        <!-- Prompt Input -->
        <EditText
            android:id="@+id/et_prompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:autofillHints=""
            android:background="@drawable/bg_input_field"
            android:hint="@string/prompt_hint"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:minLines="2"
            android:padding="14dp"
            android:textColor="#212121"
            android:textColorHint="#9E9E9E"
            android:textSize="14sp" />

        <!-- Loading Indicator -->
        <ProgressBar
            android:id="@+id/progress_loading"
            style="@android:style/Widget.Material.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginBottom="12dp"
            android:indeterminate="true"
            android:indeterminateTint="#673AB7"
            android:visibility="gone" />

        <!-- Go Button -->
        <Button
            android:id="@+id/btn_go"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_go_button"
            android:text="@string/go_button"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
